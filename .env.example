# Google Drive. OAuth is recommended for normal My Drive / personal paid storage.
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=replace_after_opening_/api/google-oauth-start
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google-oauth-callback

# Service account fallback. Works for metadata/folders, but binary uploads need a real
# Shared Drive or OAuth above because service accounts have no personal Drive quota.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key":"...","client_email":"..."}
GOOGLE_DRIVE_FOLDER_ID=replace_with_drive_folder_id
PORTAL_BASE_URL=http://localhost:5173
DAILY_REPORT_WEBHOOK_URL=https://example.com/webhook
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
TELEGRAM_CHAT_ID=123456789
AUTH_SECRET=replace_with_strong_secret
ADMIN_EMAIL=reviewsworld01@gmail.com
ADMIN_PASSWORD=replace_with_strong_admin_password
CRON_SECRET=replace_with_random_string_for_vercel_cron

# Razorpay payments
RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
